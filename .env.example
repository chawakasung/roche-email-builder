# Resend API key for sending real emails. Get one at https://resend.com/api-keys
# Copy this file to `.env` and fill in your key. The .env file is gitignored.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Google OAuth client ID for "Connect Google Sheet" button on the Media Form block.
# Create at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client IDs).
# Authorized JavaScript origins must include http://localhost:5173
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxx.apps.googleusercontent.com
